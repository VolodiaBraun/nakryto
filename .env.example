# Database
POSTGRES_USER=nakryto
POSTGRES_PASSWORD=nakryto_secret
POSTGRES_DB=nakryto_db
DATABASE_URL="postgresql://nakryto:nakryto_secret@localhost:5432/nakryto_db"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_ACCESS_SECRET=your_access_secret_here_change_in_production
JWT_REFRESH_SECRET=your_refresh_secret_here_change_in_production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# App
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Email (Resend)
RESEND_API_KEY=re_xxxx
EMAIL_FROM=noreply@nakryto.ru

# SMS (SMSC.ru)
SMSC_LOGIN=your_login
SMSC_PASSWORD=your_password

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token

# S3 (Yandex Object Storage)
S3_ENDPOINT=https://storage.yandexcloud.net
S3_BUCKET=nakryto-uploads
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_REGION=ru-central1
