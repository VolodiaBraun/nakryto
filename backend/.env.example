# Database
POSTGRES_USER=nakryto
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=nakryto_db
# In production: host = "postgres" (Docker service name), port = 5432
DATABASE_URL="postgresql://nakryto:change_me_strong_password@postgres:5432/nakryto_db"

# Redis
# In production: host = "redis" (Docker service name)
REDIS_URL="redis://redis:6379"

# JWT — generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=change_me_very_long_random_string_at_least_64_chars
JWT_REFRESH_SECRET=change_me_different_very_long_random_string_at_least_64_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# Superadmin JWT
SUPERADMIN_JWT_SECRET=change_me_superadmin_secret_at_least_64_chars

# App
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://nakryto.ru

# Email (Resend — https://resend.com)
RESEND_API_KEY=re_xxxx
EMAIL_FROM=noreply@nakryto.ru

# SMS (SMSC.ru)
SMSC_LOGIN=your_login
SMSC_PASSWORD=your_password

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token

# S3 (Yandex Object Storage)
S3_ENDPOINT=https://storage.yandexcloud.net
S3_BUCKET=nakryto-uploads
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_REGION=ru-central1
